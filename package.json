{
  "name": "obsidian-linear-vault-sync",
  "version": "0.1.0",
  "description": "Two-way sync between Obsidian and Linear. Privacy-first opt-in, mobile-ready, zero dependencies.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "linear",
    "linear-app",
    "linear-sync",
    "task-management",
    "frontmatter",
    "sync",
    "two-way-sync",
    "mobile"
  ],
  "author": "Sviatoslav Gusev <hello@gusev.biz> (https://gusev.biz)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeFiTON/obsidian-linear-vault-sync.git"
  },
  "bugs": {
    "url": "https://github.com/DeFiTON/obsidian-linear-vault-sync/issues"
  },
  "homepage": "https://github.com/DeFiTON/obsidian-linear-vault-sync#readme",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  }
}
